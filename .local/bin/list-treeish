#!/bin/bash

# Usage: ./list-treeish [-d <folder_path>] [-n <number>] [-b <branch>]
# Example: ./list-treeish -d post-purchase -n 10

FOLDER_PATH="$HOME/Klarna/klarna-app-services/services/post-purchase"
NUM_COMMITS=4
BRANCH="origin/main"

while getopts "d:n:b:" opt; do
  case $opt in
    d) FOLDER_PATH="$OPTARG" ;;
    n) NUM_COMMITS="$OPTARG" ;;
    b) BRANCH="$OPTARG" ;;
    \?) echo "Usage: $0 [-d <folder_path>] [-n <number>] [-b <branch>]" >&2
        exit 1 ;;
  esac
done

# Find the git repository root
GIT_ROOT=$(git -C "$FOLDER_PATH" rev-parse --show-toplevel 2>/dev/null || git rev-parse --show-toplevel 2>/dev/null)
if [ -z "$GIT_ROOT" ]; then
  echo "Error: Not in a git repository" >&2
  exit 1
fi

# Calculate relative path from git root to folder
if [ -d "$FOLDER_PATH" ]; then
  REL_PATH=$(realpath --relative-to="$GIT_ROOT" "$FOLDER_PATH" 2>/dev/null || echo "$FOLDER_PATH")
else
  REL_PATH="$FOLDER_PATH"
fi

pushd "$GIT_ROOT" > /dev/null || exit 1

# If branch wasn't specified and origin/main doesn't exist, default to origin/master
if [ "$BRANCH" = "origin/main" ] && ! git rev-parse --verify "$BRANCH" >/dev/null 2>&1; then
  BRANCH="origin/master"
fi

git log -n "$NUM_COMMITS" --pretty=tformat:"%H|%ct|%an|%s" "$BRANCH" -- "$REL_PATH" | while IFS='|' read -r COMMIT TS AUTHOR MSG; do
  TREE_HASH=$(git ls-tree -d "$COMMIT" "$REL_PATH" 2>/dev/null | awk '{print $3}')
  if [ -n "$TREE_HASH" ]; then
    ISO_DATE=$(date -r "$TS" +"%Y-%m-%d %H:%M:%S")
    TREE_COLOR="\033[32m"    # Green
    AUTHOR_COLOR="\033[35m"  # Purple
    TIME_COLOR="\033[36m"    # Cyan
    COMMIT_COLOR="\033[33m"  # Yellow
    RESET="\033[0m"
    printf "${TREE_COLOR}%-11s${RESET} ${AUTHOR_COLOR}%-15s${RESET} ${TIME_COLOR}%-19s${RESET} ${COMMIT_COLOR}%s${RESET} %.72s\n" "${TREE_HASH:0:11}" "${AUTHOR:0:15}" "$ISO_DATE" "${COMMIT:0:11}" "$MSG"
  fi
done

popd > /dev/null || exit 1
